    <SteadyState Duration="20" Power="1.70" Cadence="30"/>
    <SteadyState Duration="10" Power="0.40" Cadence="16"/>
    <SteadyState Duration="20" Power="1.70" Cadence="30"/>
    <SteadyState Duration="10" Power="0.40" Cadence="16"/>
    <SteadyState Duration="20" Power="1.70" Cadence="30"/>
    <SteadyState Duration="10" Power="0.40" Cadence="16"/>
    <SteadyState Duration="20" Power="1.70" Cadence="30"/>
    <SteadyState Duration="10" Power="0.40" Cadence="16"/>
    <SteadyState Duration="20" Power="1.70" Cadence="30"/>
    <SteadyState Duration="10" Power="0.40" Cadence="16"/>
    <SteadyState Duration="20" Power="1.70" Cadence="30"/>
    <SteadyState Duration="10" Power="0.40" Cadence="16"/>
    <SteadyState Duration="20" Power="1.70" Cadence="30"/>
