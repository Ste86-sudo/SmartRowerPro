    <SteadyState Duration="25" Power="0.40" Cadence="16"/>
    <SteadyState Duration="50" Power="1.32" Cadence="30"/>
    <SteadyState Duration="25" Power="0.40" Cadence="16"/>
    <SteadyState Duration="50" Power="1.32" Cadence="30"/>
    <SteadyState Duration="25" Power="0.40" Cadence="16"/>
    <SteadyState Duration="50" Power="1.32" Cadence="30"/>
