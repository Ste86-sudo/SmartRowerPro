<workout_file>
  <author>SmartRower Pro</author>
  <name>HIIT 8x50/25s</name>
  <description>8 reps of 50s @132% FTP with 25s easy. Predicted W' floor ≈ 0%. Short, sharp, honest.</description>
  <sportType>rowing</sportType>
