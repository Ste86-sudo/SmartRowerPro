<?xml version="1.0" ?>
<workout_file>
  <author>SmartRower Pro</author>
  <name>Depletion Blocks 4x3min</name>
  <description>4x3min at 110% FTP with half-time recovery: long, shallow W' drains (predicted floor ≈ 0%). VO2max territory.</description>
