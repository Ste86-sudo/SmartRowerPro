    <SteadyState Duration="100" Power="0.50" Cadence="18"/>
    <SteadyState Duration="200" Power="1.10" Cadence="26"/>
    <SteadyState Duration="100" Power="0.50" Cadence="18"/>
    <SteadyState Duration="200" Power="1.10" Cadence="26"/>
    <SteadyState Duration="100" Power="0.50" Cadence="18"/>
    <SteadyState Duration="200" Power="1.10" Cadence="26"/>
    <SteadyState Duration="100" Power="0.50" Cadence="18"/>
    <FreeRide Duration="300" FlatRoad="1"/>
  </workout>
</workout_file>
