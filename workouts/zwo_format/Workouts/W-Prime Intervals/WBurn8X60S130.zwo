    <SteadyState Duration="120" Power="0.45" Cadence="18"/>
    <SteadyState Duration="60" Power="1.30" Cadence="28"/>
    <SteadyState Duration="120" Power="0.45" Cadence="18"/>
    <SteadyState Duration="60" Power="1.30" Cadence="28"/>
    <SteadyState Duration="120" Power="0.45" Cadence="18"/>
    <SteadyState Duration="60" Power="1.30" Cadence="28"/>
    <SteadyState Duration="120" Power="0.45" Cadence="18"/>
    <SteadyState Duration="60" Power="1.30" Cadence="28"/>
    <SteadyState Duration="120" Power="0.45" Cadence="18"/>
